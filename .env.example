# Microsoft Graph API Configuration
# This file is optional - the server uses Microsoft's public client ID by default
# Copy this file to .env only if you want to use a custom Azure app registration

# Azure App Registration Details (Optional)
# If not provided, uses Microsoft's public client ID for device code flow
CLIENT_ID=d3590ed6-52b3-4102-aeff-aad2292ab01c
TENANT_ID=organizations

# Note: CLIENT_SECRET is not needed for device code flow (interactive authentication)

# Server Configuration
SERVER_NAME=microsoft-graph-mcp-server
SERVER_VERSION=0.1.0

# User Configuration
USER_TIMEZONE=Asia/Shanghai

# Search and Pagination Settings
DEFAULT_SEARCH_DAYS=90
PAGE_SIZE=5
LLM_PAGE_SIZE=20
CONTACT_SEARCH_LIMIT=10

# Calendar Search Settings
CALENDAR_SEARCH_PAST_DAYS=30
CALENDAR_SEARCH_FUTURE_DAYS=90

# Email Forwarding Settings
MAX_BCC_BATCH_SIZE=500